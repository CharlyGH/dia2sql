<function name="mitgliedschaft_trg_fun"
		window-func="false"
		returns-setof="false"
		behavior-type="CALLED ON NULL INPUT"
		function-type="VOLATILE"
		security-type="SECURITY INVOKER"
		parallel-type="PARALLEL UNSAFE"
		execution-cost="100"
		row-amount="0">
	<schema name="dim_verein"/>
	<role name="gmd"/>
	<language name="plpgsql"/>
	<return-type>
	<type name="trigger" length="0"/>
	</return-type>
	<definition> <![CDATA[  begin
        insert into hist_verein.mitgliedschaft
          (mitgliedschaft_id,gueltig_ab,gueltig_bis,mitgliedschaft_art_id,adresse_id,name,start_datum,beitrag)
        select new.mitgliedschaft_id, new.gueltig_ab, new.gueltig_bis, new.mitgliedschaft_art_id, new.adresse_id, new.name, new.start_datum, new.beitrag
        on conflict on constraint pk_mitgliedschaft
        do update set
           gueltig_ab = current_date, gueltig_bis = excluded.gueltig_bis,
           mitgliedschaft_art_id = excluded.mitgliedschaft_art_id, adresse_id = excluded.adresse_id, name = excluded.name, start_datum = excluded.start_datum, beitrag = excluded.beitrag;
