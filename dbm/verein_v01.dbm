	<column name="rollen_art_id" not-null="true">
		<type name="base_verein.id_type" length="0"/>
		<comment> <![CDATA[technische Id]]> </comment>
	</column>
	<column name="entgelt">
		<type name="base_verein.amount_type" length="0"/>
		<comment> <![CDATA[Monatsentgelt]]> </comment>
	</column>
	<constraint name="pk_rolle" type="pk-constr" table="hist_verein.rolle">
		<tablespace name="hist_verein"/>
		<columns names="rolle_id,gueltig_ab" ref-type="src-columns"/>
	</constraint>
</table>

<table name="metadata" layers="0" collapse-mode="2" max-obj-count="2" z-value="0">
	<schema name="base_verein"/>
	<role name="gmd"/>
	<tablespace name="base_verein"/>
	<position x="60" y="60"/>
	<column name="project" not-null="true">
		<type name="base_verein.text_type" length="0"/>
	</column>
	<column name="version" not-null="true">
		<type name="base_verein.count_type" length="0"/>
	</column>
	<constraint name="pk_metadata" type="pk-constr" table="base_verein.metadata">
		<tablespace name="base_verein"/>
		<columns names="version" ref-type="src-columns"/>
	</constraint>
</table>

