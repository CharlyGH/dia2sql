alter table dim_verein.funktion
      add constraint fk_funktion_person
      foreign key (person_id)
      references dim_verein.person (person_id);

alter table dim_verein.funktion
      add constraint fk_funktion_rolle
      foreign key (rolle_id)
      references dim_verein.rolle (rolle_id);

alter table dim_verein.mitgliedschaft
      add constraint fk_mitgliedschaft_mitgliedschaft_art
      foreign key (mitgliedschaft_art_id)
      references const_verein.mitgliedschaft_art (mitgliedschaft_art_id);

alter table dim_verein.mitgliedschaft
      add constraint fk_mitgliedschaft_adresse
      foreign key (adresse_id)
      references dim_verein.adresse (adresse_id);

alter table dim_verein.person
      add constraint fk_person_status_art
      foreign key (status_art_id)
      references const_verein.status_art (status_art_id);

alter table dim_verein.person
      add constraint fk_person_mitgliedschaft
      foreign key (mitgliedschaft_id)
      references dim_verein.mitgliedschaft (mitgliedschaft_id);

alter table dim_verein.rolle
      add constraint fk_rolle_rollen_art
      foreign key (rollen_art_id)
      references const_verein.rollen_art (rollen_art_id);

alter table fakt_verein.ausgaben
      add constraint fk_ausgaben_ereignis
      foreign key (ereignis_id)
      references fakt_verein.ereignis (ereignis_id);

alter table fakt_verein.beitrag
      add constraint fk_beitrag_mitgliedschaft
      foreign key (mitgliedschaft_id)
      references dim_verein.mitgliedschaft (mitgliedschaft_id);

alter table fakt_verein.entgelt
      add constraint fk_entgelt_funktion
      foreign key (funktion_id)
      references dim_verein.funktion (funktion_id);

alter table fakt_verein.ereignis
      add constraint fk_ereignis_ereignis_art
      foreign key (ereignis_art_id)
      references const_verein.ereignis_art (ereignis_art_id);

alter table fakt_verein.pruefung
      add constraint fk_pruefung_guertel_grad
      foreign key (grad_id)
      references const_verein.guertel_grad (grad_id);

alter table fakt_verein.pruefung
      add constraint fk_pruefung_person
      foreign key (person_id)
      references dim_verein.person (person_id);


create table base_verein.metadata (
    project                        base_verein.text_type not null,
    version                        base_verein.count_type not null,
    constraint                     pk_metadata
                                   primary key  (version)
                                   using index tablespace base_verein
) tablespace base_verein;





insert into base_verein.metadata (project, version)
            values ('verein', 1);

