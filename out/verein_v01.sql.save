    mitgliedschaft_id              base_verein.id_type not null,
    status_art_id                  base_verein.id_type not null,
    nachname                       base_verein.text_type not null,
    vorname                        base_verein.text_type not null,
    geburtsdatum                   base_verein.date_type not null,
    constraint                     uk_person
                                   unique  (nachname, vorname, geburtsdatum)
                                   using index tablespace dim_verein,
    constraint                     pk_person
                                   primary key  (person_id)
                                   using index tablespace dim_verein
) tablespace dim_verein;
comment on table dim_verein.person is 'Personen';

