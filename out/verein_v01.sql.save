create table hist_verein.adresse (
    adresse_id                     base_verein.id_type not null,
    gueltig_ab                     base_verein.date_type default current_date not null,
    gueltig_bis                    base_verein.date_type default '31.12.9999'::date not null,
    plz                            base_verein.text_type not null,
    stadt                          base_verein.text_type not null,
    strasse                        base_verein.text_type not null,
    haus_nr                        base_verein.text_type not null,
    postergaenzung                 base_verein.text_type,
    constraint                     pk_adresse
                                   primary key  (adresse_id, gueltig_ab)
                                   using index tablespace hist_verein
) tablespace hist_verein;
comment on table hist_verein.adresse is 'Adressen';

comment on column hist_verein.adresse.adresse_id is 'Technische Id';
comment on column hist_verein.adresse.gueltig_ab is 'automatisch erzeugtes gueltig_ab-Datum';
comment on column hist_verein.adresse.gueltig_bis is 'automatisch erzeugtes gueltig_bis-Datum';
comment on column hist_verein.adresse.plz is 'Postleitzahl';
comment on column hist_verein.adresse.stadt is 'Wohnort';
comment on column hist_verein.adresse.strasse is 'Strasse';
