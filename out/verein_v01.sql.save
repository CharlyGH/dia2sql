comment on column dim_verein.person.vorname is 'Vorname';
comment on column dim_verein.person.geburtsdatum is 'Geburtsdatum';

create or replace function dim_verein.person_trg_fun()
 returns trigger
 language plpgsql
as $function$
  begin
        insert into hist_verein.person
          (person_id,gueltig_ab,gueltig_bis,mitgliedschaft_id,status_art_id,nachname,vorname,geburtsdatum)
        select new.person_id, new.gueltig_ab, new.gueltig_bis, new.mitgliedschaft_id, new.status_art_id, new.nachname, new.vorname, new.geburtsdatum
        on conflict on constraint pk_person
        do update set
           gueltig_ab = current_date, gueltig_bis = excluded.gueltig_bis,
           mitgliedschaft_id = excluded.mitgliedschaft_id, status_art_id = excluded.status_art_id, nachname = excluded.nachname, vorname = excluded.vorname, geburtsdatum = excluded.geburtsdatum;
        return new;
  end;
$function$;


create or replace trigger person_ins_trg
       after insert on dim_verein.person
       for each row
       EXECUTE FUNCTION dim_verein.person_trg_fun();

create or replace trigger person_upd_trg
